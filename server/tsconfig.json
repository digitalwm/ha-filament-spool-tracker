{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": "../",
    "paths": {
      "@ha-addon/types": ["./types"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["../node_modules", "../client", "dist", "**/*.test.ts"]
}
